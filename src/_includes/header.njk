<header class="site-header">
    <div class="site-header__inner">
        <a class="site-header__logo" href="/" aria-label="Kind Stranger home">
            <img src="/assets/img/logo-wordmark.png" alt="Kind Stranger" width="180">
        </a>
        <button class="nav-toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Menu">
            <span class="nav-toggle__bar"></span>
            <span class="nav-toggle__bar"></span>
            <span class="nav-toggle__bar"></span>
        </button>
        <nav class="site-nav" id="site-nav" aria-label="Main">
            <ul>
                {% for item in site.nav %}
                <li><a href="{{ item.url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.label }}</a></li>
                {% endfor %}
                <li><a class="btn btn--primary btn--small" href="mailto:hello@kindstrangerhq.com">Talk to us</a></li>
            </ul>
        </nav>
    </div>
</header>
