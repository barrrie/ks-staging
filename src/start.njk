---
layout: base.njk
title: Start a project
description: "Contact Kind Stranger. Tell us about your organization and objectives, and we will respond within one business day."
permalink: /start/
---

<section class="hero">
    <div class="container">
        <div class="eyebrow">CONTACT</div>
        <h1>Start a project.</h1>
        <p class="hero__subhead">Tell us about your organization and what you are trying to accomplish. We typically respond within one business day.</p>
    </div>
</section>

<section class="section section--alt">
    <div class="container">
        <!-- [BARRIE] Formspree endpoint needed. Create a form at formspree.io and replace
             YOUR_FORM_ID below. Until then the submit will fail gracefully with the
             email fallback message. -->
        <form class="form" data-ks-form action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
            <div class="form__field">
                <label for="f-name">Name</label>
                <input id="f-name" name="name" type="text" required autocomplete="name">
            </div>
            <div class="form__field">
                <label for="f-email">Work email</label>
                <input id="f-email" name="email" type="email" required autocomplete="email">
            </div>
            <div class="form__field">
                <label for="f-company">Organization</label>
                <input id="f-company" name="company" type="text" required autocomplete="organization">
            </div>
            <div class="form__field">
                <label for="f-message">What are you trying to accomplish?</label>
                <textarea id="f-message" name="message" rows="6" required></textarea>
            </div>
            <div class="form__field">
                <label for="f-source">How did you hear about us? <span class="optional">(optional)</span></label>
                <input id="f-source" name="source" type="text">
            </div>
            <!-- honeypot -->
            <div class="form__gotcha" aria-hidden="true">
                <label for="f-gotcha">Leave this empty</label>
                <input id="f-gotcha" name="_gotcha" type="text" tabindex="-1" autocomplete="off">
            </div>
            <button class="btn btn--primary" type="submit">Send</button>
        </form>
        <div class="form__confirm" role="status" aria-live="polite"></div>

        <p class="mono mt-3" style="font-size:13px;color:var(--text-tertiary)">Prefer email? <a href="mailto:hello@kindstrangerhq.com">hello@kindstrangerhq.com</a></p>
    </div>
</section>
